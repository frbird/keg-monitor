# Server
PORT=3000
NODE_ENV=production

# Database (default: ./data/keg.db)
# DB_PATH=/app/data/keg.db

# Session secret for admin login. If unset, a secret is generated and stored in
# the data directory (.session_secret) so no human needs to know it and sessions
# survive restarts. Set only when you need a fixed secret (e.g. multi-instance).
# SESSION_SECRET=change-me-to-a-random-string

# Optional: admin user created on first db init
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# CORS origin (optional; default allows same-origin)
# CORS_ORIGIN=https://keg.example.com
